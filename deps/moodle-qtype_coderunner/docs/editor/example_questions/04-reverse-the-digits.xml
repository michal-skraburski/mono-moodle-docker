    <answer><![CDATA[#include <stdio.h>

int main(){

  int input;
  int ninput;

  printf("Enter a two-digit positive integer: ");
  ninput = scanf("%d", &input);
  if (ninput == 1 && input > 0 && input < 100)
  {
    int tens = input/10;
    int ones = input%10;
    printf("The reversal is: %d%d\n", ones, tens);
  }
  else
  {
	printf("Invalid input!\n");
  }

  return 0;
}]]></answer>
