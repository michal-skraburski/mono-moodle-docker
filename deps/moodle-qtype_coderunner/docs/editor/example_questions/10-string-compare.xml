    <answer><![CDATA[int str_cmp(char* str1, char* str2){
	if (*str1 != *str2 || *str1 == '\0' || *str2 == '\0'){
		if(*str1 < *str2) return -1;
		if(*str1 > *str2) return 1;
		return 0;
	}
	return str_cmp(str1 + 1, str2 + 1);
	
}]]></answer>
