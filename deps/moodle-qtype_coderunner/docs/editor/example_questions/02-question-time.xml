    <answer><![CDATA[#include <stdio.h>

int main(){
	char name[11];
	char age[4];
	char animal[21];
	
	printf("What is your name?\n");
	scanf(" %10s", name);
	
	printf("How old are you?\n");
	scanf(" %3s", age);
	
	printf("What is your favourite animal?\n");
	scanf(" %20s", animal);
	
	
	
	printf("You are %s, you are %s years old and your favourite animal is %s", name, age, animal);
}]]></answer>
