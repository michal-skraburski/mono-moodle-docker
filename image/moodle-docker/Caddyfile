# Shared: render a Markdown page through _layout.html. The layout picks which
# .md to load from the original request path ("/" -> index.md, "/x" -> x.md).
(rendermd) {
  templates
  rewrite * /_layout.html
  file_server
}

:80 {
  root * /srv/docs

  @new path /new /new/*
  handle @new {
    reverse_proxy webserver:80 {
      header_up X-Forwarded-Proto https
    }
  }

  @old path /old /old/*
  handle @old {
    reverse_proxy webserver-old:80 {
      header_up X-Forwarded-Proto https
    }
  }

  # Static assets (logo, images, css) served straight from /srv/docs.
  @assets path *.svg *.jpg *.jpeg *.png *.ico *.gif *.webp *.css
  handle @assets {
    file_server
  }

  # Site root renders index.md.
  @home path /
  handle @home {
    import rendermd
  }

  # "/name" renders name.md, but only if that file exists (else falls through).
  @page file {path}.md
  handle @page {
    import rendermd
  }

  # Anything else 404s.
  handle {
    respond "Not found" 404
  }
}
